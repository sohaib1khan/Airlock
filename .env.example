# =========================================================
# Airlock environment template
# Copy to .env and replace all CHANGE_ME values.
# =========================================================

# --- App ---
APP_NAME=Airlock
APP_ENV=development
APP_PORT=8000
# Display times in session UI (started / stops by). IANA name, e.g. America/New_York or Europe/London.
AIRLOCK_TIMEZONE=UTC
# Public frontend origin (used by auth/CORS/WebAuthn).
# Compose default in this project maps frontend to host port 32770.
FRONTEND_URL=http://localhost:32770

# --- Database ---
DATABASE_URL=sqlite:///./data/airlock.db

# --- JWT ---
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=8

# --- Session ---
# Generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
# Leave empty for localhost; set to your cookie domain in production.
SESSION_COOKIE_DOMAIN=
# Set true in production HTTPS deployments.
COOKIE_SECURE=false

# --- Rate limiting (slowapi) ---
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SETUP=10/minute
RATE_LIMIT_MFA=10/minute
RATE_LIMIT_PRECONNECT=10/minute

# --- Connect token (layer 2, pre-session) ---
CONNECT_TOKEN_EXPIRE_MINUTES=2

# --- Docker ---
DOCKER_SOCKET=/var/run/docker.sock
INTERNAL_DOCKER_NETWORK=airlock_internal
CONTAINER_CPU_LIMIT=2.0
CONTAINER_MEMORY_LIMIT_MB=2048

# --- Two-factor authentication (2FA) / WebAuthn ---
# For localhost testing use:
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:32770
YUBIKEY_CLIENT_ID=
YUBIKEY_SECRET_KEY=
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Airlock
WEBAUTHN_ORIGIN=http://localhost:32770

# --- Audit ---
AUDIT_LOG_FILE=./data/audit.log
AUDIT_LOG_LEVEL=INFO

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:32770

# --- Frontend (Vite; optional branding) ---
# If set, the login page shows a "Source code" link (use your public GitHub URL).
# VITE_REPO_URL=https://github.com/your-org/airlock
#
# Reverse proxy / public hostname (Vite dev server):
# - Set FRONTEND_URL to your public origin so host checks + backend CORS/WebAuthn can align.
# - Or list hosts: VITE_ALLOWED_HOSTS=localhost,127.0.0.1,vdi.example.com
# - Or allow any Host header (less strict; use only behind a trusted proxy):
#   VITE_ALLOW_ALL_HOSTS=true
#
# Behind HTTPS (NPM, Cloudflare): HMR WebSockets often need explicit client settings or disable HMR:
#   VITE_DEV_HMR_HOST=vdi.example.com
#   VITE_DEV_HMR_PROTOCOL=wss
#   VITE_DEV_HMR_CLIENT_PORT=443
# If the page stays blank, try: VITE_DEV_HMR=off

# --- Pre-built images (optional: docker-compose.hub.yml only) ---
# AIRLOCK_BACKEND_IMAGE=your-registry/airlock-backend:latest
# AIRLOCK_FRONTEND_IMAGE=your-registry/airlock-frontend:latest
# AIRLOCK_BACKEND_PORT=8000
# AIRLOCK_FRONTEND_PORT=32770
