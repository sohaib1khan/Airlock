# =========================================================
# Airlock environment template
# Copy to .env and replace CHANGE_ME values for JWT_SECRET / SESSION_SECRET.
# =========================================================

# --- App ---
APP_NAME=Airlock
APP_ENV=development
APP_PORT=8000
AIRLOCK_TIMEZONE=UTC
# Optional UI hint / fallback. CORS + WebAuthn + secure cookies infer the public URL from
# X-Forwarded-Host / X-Forwarded-Proto when behind a reverse proxy (see TRUST_FORWARDED_HEADERS).
FRONTEND_URL=http://localhost:32770

# --- Database ---
DATABASE_URL=sqlite:///./data/airlock.db

# --- JWT ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=8

# --- Session ---
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
SESSION_COOKIE_DOMAIN=
# When false, Secure cookies still apply if X-Forwarded-Proto=https (typical behind NPM).
COOKIE_SECURE=false

# Trust X-Forwarded-Host / X-Forwarded-Proto from your reverse proxy (default: true).
# Set false only if the API is reachable directly by untrusted clients without a proxy.
# TRUST_FORWARDED_HEADERS=true

# --- Rate limiting (slowapi) ---
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SETUP=10/minute
RATE_LIMIT_MFA=10/minute
RATE_LIMIT_PRECONNECT=10/minute

# --- Connect token (layer 2, pre-session) ---
CONNECT_TOKEN_EXPIRE_MINUTES=2

# --- Docker ---
DOCKER_SOCKET=/var/run/docker.sock
INTERNAL_DOCKER_NETWORK=airlock_internal
CONTAINER_CPU_LIMIT=2.0
CONTAINER_MEMORY_LIMIT_MB=2048

# --- Two-factor authentication (2FA) / WebAuthn ---
YUBIKEY_CLIENT_ID=
YUBIKEY_SECRET_KEY=
# Fallbacks when proxy headers are absent (local dev). Behind NPM, rp_id/origin are inferred per request.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Airlock
WEBAUTHN_ORIGIN=http://localhost:32770

# --- Audit ---
AUDIT_LOG_FILE=./data/audit.log
AUDIT_LOG_LEVEL=INFO

# --- CORS ---
# Optional extra allowed origins (comma-separated). Leave empty to use proxy-derived URL + dev localhost ports only.
ALLOWED_ORIGINS=

# --- Frontend (Vite) ---
# VITE_REPO_URL=https://github.com/your-org/airlock
# Docker frontend image sets VITE_DEV_HMR=off. For local npm run dev + HTTPS proxy, optionally:
# VITE_DEV_HMR_HOST=your.public.host
# VITE_DEV_HMR_PROTOCOL=wss
# VITE_DEV_HMR_CLIENT_PORT=443
# Restrict dev server hosts (default: any host allowed):
# VITE_RESTRICT_DEV_HOSTS=true
# VITE_ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# --- Pre-built images (docker-compose.hub.yml only) ---
# AIRLOCK_BACKEND_IMAGE=your-registry/airlock-backend:latest
# AIRLOCK_FRONTEND_IMAGE=your-registry/airlock-frontend:latest
# AIRLOCK_BACKEND_PORT=8000
# AIRLOCK_FRONTEND_PORT=32770
