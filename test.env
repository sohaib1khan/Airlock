# =============================================================================
# Minimal .env — public hostname is inferred from your reverse proxy
# (X-Forwarded-Host / X-Forwarded-Proto). Copy:  cp test.env .env
#
# Required once: set JWT_SECRET and SESSION_SECRET (openssl rand -hex 64).
# Optional: ALLOWED_ORIGINS / FRONTEND_URL / WEBAUTHN_* for extra static values;
#           usually leave defaults when behind NPM.
# =============================================================================

APP_NAME=Airlock
APP_ENV=development
APP_PORT=8000
AIRLOCK_TIMEZONE=UTC

FRONTEND_URL=http://localhost:32770

DATABASE_URL=sqlite:///./data/airlock.db

JWT_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=8

SESSION_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_64
SESSION_COOKIE_DOMAIN=

# Explicit true if you terminate TLS only at the app (no proxy). Behind NPM/HTTPS,
# Secure cookies are inferred from X-Forwarded-Proto when this is false.
COOKIE_SECURE=false

RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SETUP=10/minute
RATE_LIMIT_MFA=10/minute
RATE_LIMIT_PRECONNECT=10/minute

CONNECT_TOKEN_EXPIRE_MINUTES=2

DOCKER_SOCKET=/var/run/docker.sock
INTERNAL_DOCKER_NETWORK=airlock_internal
CONTAINER_CPU_LIMIT=2.0
CONTAINER_MEMORY_LIMIT_MB=2048

YUBIKEY_CLIENT_ID=
YUBIKEY_SECRET_KEY=

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Airlock
WEBAUTHN_ORIGIN=http://localhost:32770

AUDIT_LOG_FILE=./data/audit.log
AUDIT_LOG_LEVEL=INFO

# Extra CORS origins (comma-separated). Leave empty to rely on proxy auto-detection only.
ALLOWED_ORIGINS=

# Trust X-Forwarded-* from Nginx Proxy Manager / Traefik / etc. (default in app: true).
# TRUST_FORWARDED_HEADERS=true

# Vite: hosts unrestricted by default in vite.config. Restrict with VITE_RESTRICT_DEV_HOSTS=true.
# Frontend image sets VITE_DEV_HMR=off. Override only if you need dev hot-reload behind HTTPS:
# VITE_DEV_HMR_HOST=your.public.host
# VITE_DEV_HMR_PROTOCOL=wss
# VITE_DEV_HMR_CLIENT_PORT=443
